# ── Deployment mode ───────────────────────────────────────────────────────────
# "local"      → API prefix: /api/v1      (used with local Docker / Traefik setup)
# "production" → API prefix: /server/api/v1  (used with AWS ALB routing)
MODE=local

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vcollab
DB_USERNAME=postgres
DB_PASSWORD=

# ── AWS S3 ─────────────────────────────────────────────────────────────────────
AWS_REGION=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_BUCKET=

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Root users (comma-separated emails) ───────────────────────────────────────
ROOT_USER_EMAIL=admin@example.com,other@example.com

# ── Resend (email) ─────────────────────────────────────────────────────────────
RESEND_ACCESS_KEY=

# ── Google Auth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend Url ─────────────────────────────────────────────────────────────
FRONTEND_URL=

# ── CORS (optional — defaults to * if not set) ─────────────────────────────────
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
# CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
# CORS_HEADERS=*
